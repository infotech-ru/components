{
  "name": "infotech/components",
  "require": {
    "php": ">=8.4.0",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-imagick": "*",
    "ext-gd": "*",
    "phpoffice/phpspreadsheet": "^1.23",
    "ezyang/htmlpurifier": "4.19",
    "yiisoft/yii2": "2.0.53"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "infotech\\components\\": "src"
    }
  },
  "minimum-stability": "stable",
  "repositories": [
    {
      "type": "composer",
      "url": "https://asset-packagist.org"
    }
  ],
  "config": {
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    }
  }
}
